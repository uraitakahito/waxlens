# pnpm の workspace dep を可能な限り symlink で解決する。
# package.json の "@waxlens/core": "workspace:*" を満たす際、
# registry ではなく workspace 内 package を最優先で繋ぐ。
link-workspace-packages=deep
prefer-workspace-packages=true

# peer dep を自動でインストール (ink ↔ react などで効く)。
# pnpm 8 以降のデフォルトだが、意図を明示しておく。
auto-install-peers=true
