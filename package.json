{
  "name": "waxlens",
  "version": "0.0.0",
  "description": "TUI validator for WACZ archives produced by BrowserHive — one-shot validation with expandable details on failures.",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.14.1"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "waxlens": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm audit --audit-level=moderate && npm run typecheck && npm run lint && npm run format:check && npm run build && npm test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^7.0.2",
    "picocolors": "^1.1.1",
    "react": "^19.2.6",
    "yauzl-promise": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/yauzl-promise": "^4.0.1",
    "archiver": "^8.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
