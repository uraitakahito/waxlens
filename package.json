{
  "name": "waxlens-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for waxlens — @waxlens/core (validator) and @waxlens/tui (Ink TUI).",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.14.1"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "check": "npm audit --audit-level=moderate && npm run check --workspaces --if-present"
  }
}
