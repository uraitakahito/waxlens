{
  "//": [
    "Discussion on how to write comments in package.json:",
    "https://stackoverflow.com/questions/14221579/how-do-i-add-comments-to-package-json-for-npm-install"
  ],
  "name": "waxlens-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for waxlens — @waxlens/core (validator) and @waxlens/tui (Ink TUI).",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "check": "pnpm audit --audit-level=moderate && pnpm --filter @waxlens/core check && pnpm --filter @waxlens/tui check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "typescript-eslint": "^8.59.2"
  }
}
