{
  "name": "waxlens-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for waxlens — @waxlens/core (validator) and @waxlens/tui (Ink TUI).",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.14.1"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm audit --audit-level=moderate && npm run format:check && npm run check -w @waxlens/core && npm run check -w @waxlens/tui"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
