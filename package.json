{
  "name": "waxlens-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for waxlens — @waxlens/core (validator) and @waxlens/tui (Ink TUI).",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm audit --audit-level=moderate && pnpm format:check && pnpm --filter @waxlens/core check && pnpm --filter @waxlens/tui check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.0",
    "typescript-eslint": "^8.59.2"
  }
}
