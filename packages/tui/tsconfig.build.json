{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    // Safety net: don't write a single byte to `dist/` if any file
    // raised an error. See @waxlens/core's tsconfig.build.json for
    // the same rationale.
    "noEmitOnError": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*.test.ts", "**/*.test.tsx"]
}
