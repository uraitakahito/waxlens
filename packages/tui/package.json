{
  "name": "@waxlens/tui",
  "version": "0.0.0",
  "description": "Ink TUI for waxlens — reads @waxlens/core's Report and renders it interactively.",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "bin": {
    "waxlens": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run lint && npm run build && npm test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "@waxlens/core": "*",
    "commander": "^14.0.3",
    "ink": "^7.0.2",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0"
  }
}
