{
  // Inherits all options from tsconfig.json; the overrides below switch
  // emit on and pin the build output layout. Kept as a separate config so
  // the root tsconfig (which also covers test/ and *.config.ts) can stay
  // `noEmit: true` for editor / CI typecheck use.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    // Safety net: don't write a single byte to `dist/` if any file
    // raised an error. Prevents a broken build from sneaking into
    // `npm pack` / `npm publish`. The base config can't carry this
    // because it sets `noEmit: true` and the option is meaningless
    // without emit.
    "noEmitOnError": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*.test.ts"]
}
