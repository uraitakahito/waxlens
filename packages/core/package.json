{
  "name": "@waxlens/core",
  "version": "0.0.0",
  "description": "WACZ validation engine — emits a machine-readable JSON report or plain text.",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "main": "dist/public.js",
  "types": "dist/public.d.ts",
  "bin": {
    "waxlens-validate": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test",
    "prepublishOnly": "pnpm check && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "commander": "^14.0.3",
    "yauzl-promise": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.6.2",
    "@types/yauzl-promise": "^4.0.1",
    "archiver": "^8.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
