{
  "name": "@waxlens/core",
  "version": "0.0.0",
  "description": "WACZ validation engine — emits a machine-readable JSON report or plain text.",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=24.14.1"
  },
  "main": "dist/public.js",
  "types": "dist/public.d.ts",
  "bin": {
    "waxlens-validate": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run lint && npm run build && npm test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "yauzl-promise": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/yauzl-promise": "^4.0.1",
    "archiver": "^8.0.0"
  }
}
