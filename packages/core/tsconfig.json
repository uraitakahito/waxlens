{
  "compilerOptions": {
    /*
     * Type Checking
     * https://www.typescriptlang.org/tsconfig/#Type_Checking_6248
     */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    // ON intentionally (waggle has it OFF only because the hey-api generated
    // client trips it). waxlens has no generated code, so we get the stronger
    // contract — `{ foo?: T }` cannot be assigned `{ foo: undefined }`.
    "exactOptionalPropertyTypes": true,

    /*
     * Modules
     * https://www.typescriptlang.org/tsconfig/#Modules_6244
     */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,

    /*
     * Emit
     * https://www.typescriptlang.org/tsconfig/#Emit_6246
     */
    // Type-check only by default; the actual emit pass uses tsconfig.build.json.
    "noEmit": true,

    /*
     * Interop Constraints
     * https://www.typescriptlang.org/tsconfig/#Interop_Constraints_6252
     */
    // `verbatimModuleSyntax: true` makes every `import`/`export` map 1:1
    // to the emitted statement; under that mode the synthetic-default-
    // import rewrite that `esModuleInterop` controls is unreachable, so
    // we omit the latter entirely. TypeScript 6 deprecates the explicit
    // `esModuleInterop: false` form (removal slated for 7).
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /*
     * Language and Environment
     * https://www.typescriptlang.org/tsconfig/#Language_and_Environment_6254
     */
    "target": "ES2022",
    // No DOM, no JSX — @waxlens/core is Node-only and never renders
    // React. The TUI workspace adds `jsx: "react-jsx"` to its own
    // tsconfig.
    "lib": ["ES2023"]
  },
  // Root config covers source, tests, and *.config.ts so editors and the
  // typecheck script see everything; the build config narrows to src/**.
  "include": ["src/**/*", "test/**/*", "*.config.ts"],
  "exclude": ["node_modules", "dist"]
}
